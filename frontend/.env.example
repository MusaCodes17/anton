# Base URL for the backend API. During `npm run dev` the Vite proxy forwards
# /api requests to http://localhost:8000, so the default empty value works.
# Set this when serving the built frontend separately from the backend.
VITE_API_URL=

# Bearer token for the RA1.1 auth layer. MUST equal the `spa` entry in the
# backend's ANTON_TOKENS (backend/.env). Baked into the built bundle and sent
# as `Authorization: Bearer` on every request. Without it the SPA's calls 401.
# (Vite reads env from this frontend/ directory, not backend/.env.)
VITE_ANTON_SECRET=

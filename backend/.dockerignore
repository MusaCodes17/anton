# Source control
.git
.gitignore

# Python bytecode / caches
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache

# Virtual environment — never ship venv; the image builds from requirements.txt
venv
.venv
env

# Test suite — not needed in the production image
tests/

# Dev-only scripts
view_db.py
seed_data.py
test_scraper.py

# Secrets — injected at runtime via env_file or the host's secret store
.env

# SQLite files live on the mounted data volume, never inside the image
*.db
*.db.bak*
*.bak*

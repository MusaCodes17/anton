# Database
DATABASE_URL=sqlite:///./shoe_deals.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Auth (R2.1 — the security pass). REQUIRED: the server refuses to boot without
# a non-empty ANTON_SECRET. Every request to /api/* and /mcp must carry
# `Authorization: Bearer <ANTON_SECRET>` (except GET / and the health probes).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ANTON_SECRET=
# Same value, exposed to the Vite build so the SPA sends the bearer token. It is
# baked into the served JS bundle — acceptable here because the bundle only ever
# reaches the trusted single user on the trusted machine (SECURITY_PASS_PLAN §8 Q1).
VITE_ANTON_SECRET=

# Scraping Settings
SCRAPE_DELAY_SECONDS=3
MAX_CONCURRENT_SCRAPERS=2
USER_AGENT=Personal Shoe Deal Finder Bot (contact@example.com)

# CORS (for development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Scheduling
SCRAPE_SCHEDULE_HOURS=6  # Run scraping every 6 hours

# AI providers (for the chat assistant)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# MCP server URL used by the chat assistant (defaults to the local server)
MCP_SERVER_URL=http://localhost:8000/mcp

# COROS GPS watch sync (optional — leave blank to disable)
# Get these from the COROS Open Platform developer portal
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=
COROS_ACCESS_TOKEN=
COROS_OPEN_ID=

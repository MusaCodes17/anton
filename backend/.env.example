# Database (R2.2 — the DB lives OUTSIDE the repo tree).
# The live SQLite file and its backups sit in ~/anton-data/ (backups under
# ~/anton-data/backups/), never next to the source. Use an ABSOLUTE path — note
# the FOUR slashes after `sqlite:`. Replace the user segment for your machine.
# Backup convention: cp the live DB to
#   ~/anton-data/backups/shoe_deals.db.<YYYY-MM-DD>-<label>.bak
# before any structural/data-moving migration (CLAUDE.md §9 / design_decisions E4).
DATABASE_URL=sqlite:////Users/you/anton-data/shoe_deals.db

# API Settings
# API_HOST is the bind interface. Default (loopback-only) is the safe post-R2.1
# choice — the server is reachable only from this machine. To serve the LAN,
# set API_HOST=0.0.0.0; now safe because the bearer token is required (R2.1).
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# Auth (RA1.1 — per-client named tokens). REQUIRED: the server refuses to boot
# without at least one entry. Named format: "client:token,client:token,...".
# Each client gets its own revocable token — revoking one doesn't affect others.
# Clients:
#   desktop  — Claude Desktop (mcp-remote --header "Authorization: Bearer <token>")
#   loopback — Son of Anton's self-connection to /mcp (chat_service)
#   spa      — the SPA (set VITE_ANTON_SPA_TOKEN in frontend/.env to match)
# Generate tokens with: python -c "import secrets; print(secrets.token_hex(32))"
ANTON_TOKENS=desktop:REPLACE_ME_desktop,loopback:REPLACE_ME_loopback,spa:REPLACE_ME_spa

# Capability-URL token for the claude.ai connector (RA1.1 — interim, per
# REMOTE_ACCESS_PLAN.md §6 RA1.1). The connector is configured with URL:
#   https://<host>/mcp/<ANTON_CONNECTOR_TOKEN>
# No auth credentials needed in the connector UI — the URL IS the credential.
# Leave empty if not using the claude.ai connector (local dev is fine without it).
ANTON_CONNECTOR_TOKEN=

# Chat rate limiting (R2 — the R2.1-adjacent throttle). Backstops paid LLM spend:
# R2.1 stopped *anonymous* spend, this caps an authenticated-but-looping client
# on POST /api/chat/message. Token bucket, per client IP, in-process (429 on
# exceed). Defaults below are generous for a human, a hard stop for a runaway
# loop; raise them if legitimate use ever hits the limit. See design_decisions E8.
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_RATE_LIMIT_BURST=20

# Scraping Settings
SCRAPE_DELAY_SECONDS=3
MAX_CONCURRENT_SCRAPERS=2
USER_AGENT=Personal Shoe Deal Finder Bot (contact@example.com)

# CORS (for development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Scheduling
SCRAPE_SCHEDULE_HOURS=6  # Run scraping every 6 hours

# AI providers (for the chat assistant)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# MCP server URL used by the chat assistant (defaults to the local server)
MCP_SERVER_URL=http://localhost:8000/mcp

# COROS GPS watch sync (optional — leave blank to disable)
# Get these from the COROS Open Platform developer portal
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=
COROS_ACCESS_TOKEN=
COROS_OPEN_ID=

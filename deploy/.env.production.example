# Anton production environment template.
# Copy this to .env (or load directly into the host's secret store) and fill
# in every REPLACE_ME value before deploying.
# Never commit the filled-in version; it contains credentials.

# Database — path inside the container's mounted data volume.
DATABASE_URL=sqlite:////data/shoe_deals.db

# API bind: 0.0.0.0 is correct for the container (Caddy sits in front and the
# host only exposes port 8000 on 127.0.0.1 — see docker-compose.yml).
API_HOST=0.0.0.0
API_PORT=8000

# Auth — named per-client bearer tokens (RA1.1 / design_decisions E9).
# Format: "name:token,name:token,..."
# Generate each token: python -c "import secrets; print(secrets.token_hex(32))"
# Add one entry per client; revoking a client = remove its entry + restart.
#   desktop  — Claude Desktop (mcp-remote --header "Authorization: Bearer <token>")
#   loopback — Son of Anton's self-connection to /mcp
ANTON_TOKENS=desktop:REPLACE_ME,loopback:REPLACE_ME

# OAuth 2.1 connector auth (RA1.1b — replaces capability-URL, design_decisions E9).
# Set all five vars together to enable the claude.ai connector via OAuth 2.1 + PKCE.
# ANTON_HOST_URL is also used as the OAuth issuer URL in /.well-known/oauth-authorization-server.
ANTON_HOST_URL=https://YOUR_DOMAIN
ANTON_LOGIN_PASSWORD=REPLACE_ME
ANTON_OAUTH_CLIENT_ID=claude-ai-connector
ANTON_OAUTH_CLIENT_SECRET=
ANTON_OAUTH_REDIRECT_URI=REPLACE_ME

# Chat rate limiting (design_decisions E8 — in-process, single-worker only).
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_RATE_LIMIT_BURST=20

# Scraping politeness (design_decisions D3 — never bypass).
SCRAPE_DELAY_SECONDS=3
MAX_CONCURRENT_SCRAPERS=2
USER_AGENT=Personal Shoe Deal Finder Bot (contact@example.com)

# AI providers (for Son of Anton).
ANTHROPIC_API_KEY=REPLACE_ME
OPENAI_API_KEY=
GOOGLE_API_KEY=

# MCP self-reference: Son of Anton points back at this same process (loopback).
MCP_SERVER_URL=http://localhost:8000/mcp

# Timezone (also set via Docker ENV in the Dockerfile, explicit here too).
TZ=America/Toronto
